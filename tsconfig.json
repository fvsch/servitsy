{
	"include": ["./src"],
	"compilerOptions": {
		"module": "nodenext",
		"target": "es2022",
		"lib": ["es2022"],
		"types": ["node"],
		"rootDir": "./src",
		"outDir": "./lib",
		"strict": true,
		"allowImportingTsExtensions": true,
		"erasableSyntaxOnly": true,
		"isolatedModules": true,
		"removeComments": true,
		"rewriteRelativeImportExtensions": true,
		"verbatimModuleSyntax": true
	}
}
